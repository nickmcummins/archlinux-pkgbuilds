# Maintainer: Nick M Cummins <nickmcummins at linuxmail dot org>

pkgname=pharos-git
_pkgname=pharos
pkgver=r262.b0129ae
pkgrel=1
pkgdesc='An Automated static analysis tools for binary programs (git version)'
arch=('x86_64')
url='https://github.com/cmu-sei/pharos'
license=('BSD')
depends=('z3' 'rose')
makedepends=('cmake')
conflicts=('pharos')
provides=('pharos')
source=("${_pkgname}::git+https://github.com/cmu-sei/pharos.git" 'cmake-remove-boost-system.patch')
sha256sums=('SKIP' 'SKIP')

pkgver() {
	cd ${srcdir}/${_pkgname}
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd ${srcdir}/${_pkgname}

    patch -Np0 -i ${srcdir}/cmake-remove-boost-system.patch

    mkdir -p cmake-build-release && cd cmake-build-release

    jobs=$(if ${ARCHLINUX_MAKEPKG_MAKE_JOBS+"false"}; then echo 1; else echo $ARCHLINUX_MAKEPKG_MAKE_JOBS; fi)

    cmake .. \
     -DCMAKE_INSTALL_PREFIX=/usr \
     -DCMAKE_BUILD_TYPE=Release

    make -j$jobs
}

package() {
    cd ${srcdir}/${_pkgname}/cmake-build-release
    make DESTDIR="${pkgdir}" install
}
