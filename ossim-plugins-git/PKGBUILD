# Maintainer: Nick M Cummins <nickmcummins at linuxmail dot org>

pkgname=ossim-plugins-git
_pkgname=ossim-plugins
pkgver=r477.7970ead
pkgrel=1
pkgdesc="Plugin libraries providing functional extensions to core OSSIM library (git checkout)"
url="http://www.ossim.org"
license=('LGPL')
arch=('i686' 'x86_64')
depends=('ossim')
makedepends=('cmake')
optdepends=()
provides=('ossim-plugins')
conflicts=('ossim-plugins')
source=("${_pkgname}::git+https://github.com/ossimlabs/ossim-plugins.git" 'ossimPreferences.txt' 'ossim.sh')
md5sums=('SKIP' 'SKIP' 'SKIP')

pkgver() {
    cd ${srcdir}/${_pkgname}
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd $srcdir/$_pkgname
    
    mkdir -p cmake-build-release && cd cmake-build-release

    jobs=$(if ${ARCHLINUX_MAKEPKG_MAKE_JOBS+"false"}; then echo 1; else echo $ARCHLINUX_MAKEPKG_MAKE_JOBS; fi)

    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_MODULE_PATH=/usr/lib/cmake/ossim \
        -DBUILD_DEM_PLUGIN=ON \
        -DUSE_OSSIM_JSONCPP=OFF
    make -j$jobs
}

package() {
    cd ${srcdir}/${_pkgname}/cmake-build-release
    make DESTDIR="${pkgdir}/" install
    
    mkdir -p ${pkgdir}/etc/ossim
    install -D -m777 "${srcdir}/ossimPreferences.txt" "${pkgdir}/etc/ossim/preferences.conf"

    mkdir -p ${pkgdir}/etc/profile.d
    install -D -m755 "${srcdir}/ossim.sh" "${pkgdir}/etc/profile.d/ossim.sh"
}

