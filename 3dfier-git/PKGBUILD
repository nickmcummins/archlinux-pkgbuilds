# Maintainer: Nick M Cummins <nickmcummins at linuxmail dot org>

pkgname=3dfier-git
_pkgname=3dfier
pkgver=1.4.0.r1491.b77ab96
pkgrel=1
pkgdesc="Takes 2D GIS datasets (e.g. topographical datasets) and '3dfies' them by lifting every polygon to 3D. (git version)"
url="http://tudelft3d.github.io/3dfier"
license=('GPL')
arch=('i686' 'x86_64')
depends=('lastools')
makedepends=('cmake')
optdepends=( )
source=("git+https://github.com/tudelft3d/3dfier.git" 'CMakeLists.txt.patch')
provides=('3dfier')
md5sums=('SKIP' 'SKIP')

pkgver() {
	cd ${srcdir}/${_pkgname}
	# Use the tag of the last commit
	REVISION=$(printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)")
	GITVERSION=$(git describe --long --tags | sed -r 's/^v//;s/([^-]*-g)/r\1/;s/-/./g')
	VERSION=$(python -c "import sys; print(sys.argv[1].split('.r')[0])" ${GITVERSION})
	printf "${VERSION}.${REVISION}"
}

build() {
  cd $srcdir/$_pkgname
 
  patch -Np0 -i ${srcdir}/CMakeLists.txt.patch
  
  jobs=$(if ${ARCHLINUX_MAKEPKG_MAKE_JOBS+"false"}; then echo 1; else echo $ARCHLINUX_MAKEPKG_MAKE_JOBS; fi)
  
  mkdir -p cmake-build-release && cd cmake-build-release
  cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
  make -j$jobs
}


package() {
	cd ${srcdir}/${_pkgname}/cmake-build-release
	make DESTDIR="${pkgdir}/" install
}

